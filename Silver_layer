from pyspark import pipelines as dp
from pyspark.sql import functions as F
from pyspark.sql import Window

@dp.materialized_view(
    name="dataengineering.video1.user_cleand_csv",
    comment="Cleaned user data with fixed user_id format and duplicates removed"
)
def users_silver():
    """
    Silver layer: Clean the user data by:
    1. Converting user_id from string 'USR_XXXX' format to integer XXXX
    2. Removing duplicate records based on user_id (keeps first occurrence)
    """
    # Read from bronze layer
    df = spark.read.table("bronze_users")
    
    # TRANSFORMATION 1: Remove 'USR_' prefix and convert to integer
    # Using regexp_replace to remove the prefix, then cast to integer
    df = df.withColumn(
        "user_id",
        F.regexp_replace(F.col("user_id"), "USR_", "").cast("int")
    )
    
    # TRANSFORMATION 2: Remove duplicates (keep first occurrence)
    # Using window function to assign row numbers partitioned by user_id
    # ordered by all columns to ensure deterministic behavior
    window_spec = Window.partitionBy("user_id").orderBy(
        "first_name", "last_name", "email", "signup_date", "country", "referral_source"
    )
    
    df = df.withColumn("row_num", F.row_number().over(window_spec))
    df = df.filter(F.col("row_num") == 1).drop("row_num")
    
    return df
