from pyspark import pipelines as dp
from pyspark.sql import functions as F
from pyspark.sql.window import Window

@dp.materialized_view(
    name="dataengineering.video1.insights_gold",
    comment="Analytics insights: day of week and referral source analysis"
)
def insights_gold():
    """
    Gold layer: Generate analytics insights including:
    1. Signup counts by day of week
    2. Signup counts by referral source
    """
    # Read cleaned silver data
    df = spark.read.table("dataengineering.video1.user_cleand_csv")
    
    # Parse the signup_date column to extract day of week
    # Handle multiple date formats: "M/d/yy" and "M.d.yy"
    df = df.withColumn(
        "signup_date_normalized",
        F.regexp_replace(F.col("signup_date"), r"\.", "/")
    )
    
    df = df.withColumn(
        "signup_date_parsed",
        F.to_date(F.col("signup_date_normalized"), "M/d/yy")
    )
    
    df = df.withColumn(
        "day_of_week",
        F.date_format(F.col("signup_date_parsed"), "EEEE")
    )
# Aggregate by day of week
    day_of_week_stats = df.groupBy("day_of_week").agg(
        F.count("*").alias("signup_count")
    ).withColumn(
        "percentage",
        F.round((F.col("signup_count") / F.sum("signup_count").over(Window.partitionBy())) * 100, 2)
    ).select(
        F.lit("day_of_week").alias("dimension"),
        F.col("day_of_week").alias("dimension_value"),
        F.col("signup_count"),
        F.col("percentage")
    )
    
    # Aggregate by referral source
    referral_stats = df.groupBy("referral_source").agg(
        F.count("*").alias("signup_count")
    ).withColumn(
        "percentage",
        F.round((F.col("signup_count") / F.sum("signup_count").over(Window.partitionBy())) * 100, 2)
    ).select(
        F.lit("referral_source").alias("dimension"),
        F.col("referral_source").alias("dimension_value"),
        F.col("signup_count"),
        F.col("percentage")
    )
    
    # Union both analyses
    result = day_of_week_stats.union(referral_stats)
    
    return result


@dp.materialized_view(
    name="pipline_practice.section1.insights_gold",
    comment="Copy of insights in pipline_practice schema"
)
def insights_gold_copy():
    """
    Additional copy of gold insights in the pipline_practice schema.
    """
    return spark.read.table("dataengineering.video1.insights_gold")
